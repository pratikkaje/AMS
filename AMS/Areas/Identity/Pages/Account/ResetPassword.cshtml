@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Reset password";
}

<div class="container">
    <div class="row">
        <div class="col-lg-4 col-md-6 ml-auto mr-auto" style="padding-top: 5em;">
            <div class="card card-signup">
                <form method="post" class="form">
                    <div class="card-header card-header-primary text-center">
                        <h4 class="card-title">Reset Password</h4>
                    </div>
                    @*<div asp-validation-summary="All" class="text-danger"></div>*@
                    <div class="card-body">
                        <input asp-for="Input.Code" type="hidden" />
                        <div class="input-group">
                            <div class="input-group-prepend">
                                <span class="input-group-text">
                                    <i class="material-icons">mail</i>
                                </span>
                            </div>
                            <input asp-for="Input.Email" class="form-control" placeholder="Email">
                            
                        </div>
                        <span asp-validation-for="Input.Email" class="text-danger offset-2"></span>

                        <div class="input-group">
                            <div class="input-group-prepend">
                                <span class="input-group-text">
                                    <i class="material-icons">lock_outline</i>
                                </span>
                            </div>
                            <input asp-for="Input.Password" class="form-control" placeholder="Password">
                        </div>
                        <span asp-validation-for="Input.Password" class="text-danger offset-2"></span>

                        <div class="input-group">
                            <div class="input-group-prepend">
                                <span class="input-group-text">
                                    <i class="material-icons">lock_outline</i>
                                </span>
                            </div>
                            <input asp-for="Input.ConfirmPassword" class="form-control" placeholder="Confirm Password">
                        </div>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger offset-2"></span>

                        <div class="footer text-center">
                            <button type="submit" class="btn btn-primary">Reset</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
