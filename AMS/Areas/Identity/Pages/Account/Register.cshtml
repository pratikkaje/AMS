@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="page-header-image header-filter" style="background-image: url('../../images/bg7.jpg'); background-size: cover; background-position: top center;">
    <div class="container">
        <div class="row">
            <div class="col-lg-4 col-md-6 ml-auto mr-auto" style="padding-top: 5em;">
                <div class="card card-signup">
                    <form asp-route-returnUrl="@Model.ReturnUrl" method="post" id="register" class="form">
                        <div class="card-header card-header-primary text-center">
                            <h4 class="card-title">Register</h4>
                            <div class="social-line">
                                <a href="#pablo" class="btn btn-just-icon btn-link">
                                    <i class="fa fa-facebook-square"></i>
                                </a>
                                <a href="#pablo" class="btn btn-just-icon btn-link">
                                    <i class="fa fa-twitter"></i>
                                </a>
                                <a href="#pablo" class="btn btn-just-icon btn-link">
                                    <i class="fa fa-google-plus"></i>
                                </a>
                            </div>
                        </div>
                        @*<div asp-validation-summary="All" class="text-danger"></div>*@
                        <div class="card-body">
                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text">
                                        <i class="material-icons">mail</i>
                                    </span>
                                </div>
                                <input asp-for="Input.Email" class="form-control" placeholder="Email">
                            </div>
                            <span asp-validation-for="Input.Email" class="text-danger offset-2"></span>

                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text">
                                        <i class="material-icons">lock_outline</i>
                                    </span>
                                </div>
                                <input asp-for="Input.Password" class="form-control" placeholder="Password">
                            </div>
                            <span asp-validation-for="Input.Password" class="text-danger offset-2"></span>

                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text">
                                        <i class="material-icons">lock_outline</i>
                                    </span>
                                </div>
                                <input asp-for="Input.ConfirmPassword" class="form-control" placeholder="Confirm Password">
                            </div>
                            <span asp-validation-for="Input.ConfirmPassword" class="text-danger offset-2"></span>
                        </div>
                        <div class="footer text-center">
                            <button type="submit" class="btn btn-primary">Register</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
